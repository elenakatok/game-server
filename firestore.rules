rules_version = '2';
// Emulator-only, for placeLatecomer integration tests. The Admin SDK bypasses
// rules; this file exists so `firebase emulators:exec --only firestore` has a
// rules target. Not deployed anywhere.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
